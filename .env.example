# CamoCam Frontend Configuration
# Copy this file to .env and fill in the values for your environment

# Backend API Base URL
# Examples:
#   Local development: http://localhost:8000/api
#   Android emulator: http://10.0.2.2:8000/api
#   ngrok tunnel: https://xxxx-xx-xxx-xxx-xx.ngrok-free.app/api
#   Production: https://api.camocam.com/api
API_BASE_URL=https://xxxx-xx-xxx-xxx-xx.ngrok-free.app/api
